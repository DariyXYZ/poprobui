BOT_TOKEN=your_bot_token_here
API_URL=http://localhost:8000
# Shared secret with api's INTERNAL_API_TOKEN — lets the bot call api's
# wallet/pdf endpoints as a trusted service (bypasses Telegram initData
# verification, which only a browser Mini App can produce). Generate with:
# openssl rand -hex 32
INTERNAL_API_TOKEN=
MINIAPP_URL=https://your-app.railway.app
# BotFather → your bot → Payments → ЮKassa → provider token
YOOKASSA_PROVIDER_TOKEN=
# Comma-separated Telegram usernames (no @) or numeric ids allowed to use /gift
GIFT_USERNAMES=
GIFT_USER_IDS=
