# Needed to verify Telegram Mini App initData (HMAC) — same bot as bot/.env
BOT_TOKEN=your_bot_token_here
# Shared secret with bot/.env's INTERNAL_API_TOKEN — see bot/.env.example
INTERNAL_API_TOKEN=
# Comma-separated origins allowed to call this API from a browser (the
# deployed miniapp's origin — GitHub Pages default shown, adjust if you add
# a custom domain via miniapp/CNAME)
ALLOWED_ORIGINS=https://dariyxyz.github.io
# How old a Mini App initData payload may be before it's rejected, in seconds
INIT_DATA_MAX_AGE_SECONDS=86400
# Where poprobui.db, generated PDFs, and balances.json live — point this at
# a mounted persistent volume in production, or data is lost on redeploy
DATA_DIR=
